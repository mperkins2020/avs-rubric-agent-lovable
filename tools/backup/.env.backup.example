# Copy to .env.backup and fill in. NEVER commit .env.backup (gitignored).

# REQUIRED — Postgres connection string.
# Supabase dashboard → Project Settings → Database → Connection string → URI.
# Use the "Session" / direct connection (port 5432), not the pooler, for pg_dump.
# Format: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
SUPABASE_DB_URL=

# OPTIONAL — upload to a bucket you own. Leave blank to keep local-only.
# BACKUP_S3_URI=s3://my-valuetempo-backups/supabase
# BACKUP_S3_ENDPOINT=        # only for S3-compatible providers (R2, B2, etc.)

# OPTIONAL — overrides
# BACKUP_DIR=                 # default: tools/backup/dumps
# RETENTION_DAYS=30          # local dumps older than this are pruned; 0 = keep all
